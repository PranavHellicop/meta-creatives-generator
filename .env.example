# OpenAI — single key powers strategy reasoning, image generation, and vision scoring
OPENAI_API_KEY=sk-...

# Reasoning model for the strategy engine (research, angles, briefs, art direction, scoring)
REASONING_MODEL=gpt-4o-mini

# Image model + quality. The image model generates the complete ad (imagery + text) in one pass.
# Founder mode uses the image-edit endpoint, which REQUIRES a gpt-image-* model.
# gpt-image-1 is a cheaper fallback (quality: low | medium | high).
IMAGE_MODEL=gpt-image-2
IMAGE_QUALITY=high

# Where generated files (founder photos, final PNGs) are stored, relative to project root.
DATA_DIR=data

# Base URL of this app. Optional — the Canva OAuth redirect is derived from the
# live request origin, so the flow adapts to whatever host/port you run on.
APP_URL=http://127.0.0.1:3000

# Canva Connect API — "Export to Canva" integration.
# Register an integration at https://www.canva.dev/ to get these.
# The redirect URI adapts to the running origin automatically, so leave it unset for
# local dev — but you MUST register every origin you use (each loopback port, e.g.
# http://127.0.0.1:3000/api/canva/callback and :3001, plus your prod URL) in the
# integration's "Redirect URLs". OAuth rejects any URI not on that allowlist.
# Set CANVA_REDIRECT_URI only to FORCE a fixed URI (e.g. prod behind a proxy).
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
# CANVA_REDIRECT_URI=https://your-domain.com/api/canva/callback
