// Meta Creatives Generator — data model
// Project -> (BusinessProfile, MarketProfile, FounderPhotos, Angles, CreativeBriefs -> Creatives)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Project {
  id            String   @id @default(cuid())
  // name/niche/service/offer/audience are no longer entered directly — the form is
  // prompt-first. They're set to provisional placeholders at creation and overwritten
  // by the intake step (src/lib/pipeline/intake.ts), which derives them from the
  // prompt + provided copy + website research. Kept non-null to avoid null-handling.
  name          String
  niche         String
  service       String
  audience      String
  offer         String
  prompt        String?          // free-text description of the business/need (primary intake signal)
  websiteUrl    String?
  igUrl         String?
  fbUrl         String?
  notes         String?
  featureFounder Boolean @default(false)
  creativeCount Int      @default(10)

  // Pipeline status: idle | researching | profiling | market | angles | briefs | art | rendering | scoring | done | error | draft
  // "draft" = a stopped/incomplete generation the user can edit & regenerate or delete.
  status        String   @default("idle")
  statusDetail  String?  // human-readable progress, e.g. "Rendering 3/10"
  error         String?
  stopRequested Boolean  @default(false) // set by the stop endpoint; the running pipeline checks it and bails to "draft"

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  rawResearch     String?          // raw scraped website text (truncated)
  visualAnchor    String?          // locked 50-75 word image generation modifier for this brand
  providedPrompts String?          // JSON array of operator prompts (each = a per-creative brief; combined into `prompt` for global stages)
  providedHeadlines String?        // JSON array of user-supplied headlines (one per line; used in order, AI fills the rest)
  providedSubheadlines String?     // JSON array of user-supplied subheadlines (one per line; used in order, AI fills the rest)
  providedCtas      String?        // JSON array of user-supplied CTAs (one per line in the form)
  referenceDigest String?          // structure/placement patterns learned from the data/references swipe folder (if any)
  designDirectives String?         // explicit design/placement/color instructions mined from the operator prompt (src/lib/pipeline/designDirectives.ts)
  logoRequested   Boolean @default(false) // true only if the operator explicitly asked for a logo; otherwise NO logo is ever rendered/invented
  businessProfile BusinessProfile?
  marketProfile   MarketProfile?
  founderPhotos   FounderPhoto[]
  angles          Angle[]
  briefs          CreativeBrief[]
  creatives       Creative[]
}

model FounderPhoto {
  id          String  @id @default(cuid())
  projectId   String
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  originalPath String // relative path under /data
  cutoutPath  String?  // background-removed PNG
  createdAt   DateTime @default(now())
}

model BusinessProfile {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  data      String   // JSON: brandName, industry, service, offer, founder, brandTone, socialProof[], testimonials[], usp, pricingSignals, brandColors[], visualStyle
  createdAt DateTime @default(now())
}

model MarketProfile {
  id        String   @id @default(cuid())
  projectId String   @unique
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  data      String   // JSON: painPoints[], desiredOutcomes[], motivations[], objections[], commonOffers[], buyerPsychology, visualExpectations, adPatterns
  createdAt DateTime @default(now())
}

model Angle {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String   // pain | transformation | authority | offer | case-study | urgency | comparison | myth-busting | convenience | social-proof | community | expert | lifestyle | future-self | risk-reversal
  hook      String
  rationale String
  selected  Boolean  @default(false)
  preScore  Float    @default(0)
  createdAt DateTime @default(now())

  brief     CreativeBrief?
}

model CreativeBrief {
  id        String   @id @default(cuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  angleId   String   @unique
  angle     Angle    @relation(fields: [angleId], references: [id], onDelete: Cascade)
  data      String   // JSON: goal, emotion, headline, subheadline, supportingCopy, offer, cta, visualConcept, trustElements[], authorityElements[], socialProofElements[], layoutType, designStyle, artDirection{...}
  layoutType String
  createdAt DateTime @default(now())

  creative  Creative?
}

model Creative {
  id           String   @id @default(cuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  briefId      String   @unique
  brief        CreativeBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)

  index        Int      // 1-based position in the batch
  mode         String   // founder | banner
  layoutType   String
  imagePrompt  String?  // backdrop-only prompt sent to image model (null for pure-CSS banners)
  bgImagePath  String?  // AI-generated backdrop, relative under /data
  founderCutoutPath String? // chosen founder cutout for this creative
  finalPngPath String?  // exported 1080x1080 PNG, relative under /data

  editableText String   // JSON: { headline, subheadline, supportingCopy, offer, cta } — mutable for live editing
  artDirection String   // JSON snapshot of colors/typography used by the renderer

  score        String?  // JSON: per-criterion scores + notes
  overallScore Float?

  versions     CreativeVersion[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// Edit history for a creative (Tier-1 prompt-based edits). Version 1 is the
// original render; each subsequent version is one prompt-based edit. The active
// version is whichever pngPath currently sits on Creative.finalPngPath, so
// reverting just points finalPngPath (and the cached score) back at a version.
model CreativeVersion {
  id           String   @id @default(cuid())
  creativeId   String
  creative     Creative @relation(fields: [creativeId], references: [id], onDelete: Cascade)

  index        Int      // 1 = original, 2+ = edits
  pngPath      String   // relative under /data
  instruction  String?  // null for the original; the edit instruction otherwise
  score        String?  // JSON score snapshot at this version
  overallScore Float?

  createdAt    DateTime @default(now())

  @@index([creativeId])
}

// Canva Connect OAuth tokens. This is a single-user local app, so there is exactly
// one row (id = "canva"); we upsert it on connect and refresh.
model CanvaAuth {
  id           String   @id @default("canva")
  accessToken  String
  refreshToken String
  expiresAt    DateTime // when the access token expires
  scope        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
